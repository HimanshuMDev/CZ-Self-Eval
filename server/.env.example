# MongoDB Atlas connection URI — replace <db_password> with your actual password
MONGODB_URI=mongodb+srv://himanshum_db_user:<db_password>@cluster0.xhlx1mq.mongodb.net/cz-self-eval?retryWrites=true&w=majority

# Server port (Vite proxies /api/sessions → this port)
PORT=4001

# CORS allowed origin (your dashboard dev server)
CORS_ORIGIN=http://localhost:5173

# ── LLM providers (any one enables AI for Generate Evidence + LLM judge) ──
# Backend ladder tries in order: Anthropic → OpenAI → Gemini → heuristic.
# Copy whichever key(s) you already use in the main CZ-AI agent repo's .env.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash        # optional: override default model
GEMINI_TEMPERATURE=0.3                # optional: generator creativity
GEMINI_MAX_TOKENS=3000                # optional: max response tokens

# ── Reliability timeouts (ms, optional — defaults shown) ──
CZ_JUDGE_TIMEOUT_MS=30000             # per LLM-judge call
CZ_SCENARIO_TIMEOUT_MS=180000         # per scenario (all repeats + judge)
CZ_EVAL_RUN_TIMEOUT_MS=1200000        # whole-run wall-clock (20 min)
